{
  "manifest_version": 3,
  "name": "MetaTFT Cào tướng & trang bị",
  "version": "1.2",
  "permissions": ["scripting", "tabs", "downloads"],
  "host_permissions": ["https://www.metatft.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}