{
  "manifest_version": 3,
  "name": "Privacy Shield Pro",
  "version": "1.2.1",
  "description": "Bảo vệ quyền riêng tư, quản lý Cookie và giả mạo cấu hình.",
  "permissions": [
    "declarativeNetRequest",
    "scripting",
    "contentSettings",
    "storage",
    "tabs",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}